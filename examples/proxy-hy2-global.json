{
  "log": {
    "level": "info"
  },
  "experimental": {
    "cache_file": {
      "enabled": true
    }
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7890
    }
  ],
  "outbounds": [
    {
      "type": "hysteria2",
      "tag": "hy2",
      "server": "203.0.113.10",
      "server_port": 443,
      "password": "YOUR_HYSTERIA2_PASSWORD",
      "obfs": {
        "type": "salamander",
        "password": "YOUR_HYSTERIA2_OBFS_PASSWORD"
      },
      "tls": {
        "enabled": true,
        "server_name": "203.0.113.10",
        "insecure": true,
        "certificate_public_key_sha256": [
          "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
        ]
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    }
  ],
  "route": {
    "rules": [
      {
        "action": "sniff"
      },
      {
        "ip_cidr": [
          "203.0.113.10/32"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "direct"
      },
      {
        "protocol": [
          "bittorrent"
        ],
        "action": "route",
        "outbound": "block"
      }
    ],
    "final": "hy2"
  }
}
