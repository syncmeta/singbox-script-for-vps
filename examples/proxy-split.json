        "download_detour": "reality-tcp",
        "update_interval": "1d"
      }
    ],
    "rules": [
      {
        "ip_cidr": [
          "203.0.113.10/32"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "direct"
