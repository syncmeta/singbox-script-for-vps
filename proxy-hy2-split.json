{
  "log": {
    "level": "info"
  },
  "experimental": {
    "cache_file": {
      "enabled": true
    }
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7890
    }
  ],
  "outbounds": [
    {
      "type": "hysteria2",
      "tag": "hy2",
      "server": "YOUR_SERVER_IP",
      "server_port": 443,
      "password": "YOUR_HYSTERIA2_PASSWORD",
      "obfs": {
        "type": "salamander",
        "password": "YOUR_HYSTERIA2_OBFS_PASSWORD"
      },
      "tls": {
        "enabled": true,
        "server_name": "YOUR_SERVER_IP",
        "insecure": true,
        "certificate_public_key_sha256": [
          "YOUR_HYSTERIA2_CERT_PUBLIC_KEY_SHA256"
        ]
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    }
  ],
  "route": {
    "rule_set": [
      {
        "type": "remote",
        "tag": "geosite-cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-cn.srs",
        "download_detour": "hy2",
        "update_interval": "1d"
      },
      {
        "type": "remote",
        "tag": "geoip-cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs",
        "download_detour": "hy2",
        "update_interval": "1d"
      }
    ],
    "rules": [
      {
        "ip_cidr": [
          "YOUR_SERVER_IP/32"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "direct"
      },
      {
        "domain_suffix": [
          ".cn",
          ".中国",
          ".中國"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": [
          "geosite-cn",
          "geoip-cn"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "protocol": [
          "bittorrent"
        ],
        "action": "route",
        "outbound": "block"
      }
    ],
    "final": "hy2"
  }
}
