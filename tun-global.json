{
  "log": {
    "level": "info"
  },
  "dns": {
    "servers": [
      {
        "tag": "cloudflare-doh",
        "address": "https://1.1.1.1/dns-query",
        "detour": "trojan-tcp",
        "strategy": "prefer_ipv4"
      },
      {
        "tag": "local",
        "address": "local"
      }
    ],
    "final": "cloudflare-doh",
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": [
        "172.19.0.1/30"
      ],
      "mtu": 1500,
      "auto_route": true,
      "stack": "system"
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7890
    }
  ],
  "outbounds": [
    {
      "type": "trojan",
      "tag": "trojan-tcp",
      "server": "YOUR_SERVER_IP",
      "server_port": 443,
      "password": "YOUR_TROJAN_PASSWORD",
      "tls": {
        "enabled": true,
        "server_name": "YOUR_SERVER_IP",
        "insecure": true
      }
    },
    {
      "type": "hysteria2",
      "tag": "hy2",
      "server": "YOUR_SERVER_IP",
      "server_port": 443,
      "password": "YOUR_HYSTERIA2_PASSWORD",
      "obfs": {
        "type": "salamander",
        "password": "YOUR_HYSTERIA2_OBFS_PASSWORD"
      },
      "tls": {
        "enabled": true,
        "server_name": "YOUR_SERVER_IP",
        "insecure": true,
        "certificate_public_key_sha256": [
          "YOUR_HYSTERIA2_CERT_PUBLIC_KEY_SHA256"
        ]
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "rules": [
      {
        "network": [
          "tcp",
          "udp"
        ],
        "port": 53,
        "action": "hijack-dns"
      },
      {
        "protocol": [
          "dns"
        ],
        "action": "hijack-dns"
      },
      {
        "ip_cidr": [
          "YOUR_SERVER_IP/32"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "direct"
      },
      {
        "network": [
          "udp"
        ],
        "port": 443,
        "action": "route",
        "outbound": "block"
      },
      {
        "network": [
          "tcp"
        ],
        "action": "route",
        "outbound": "trojan-tcp"
      },
      {
        "network": [
          "udp"
        ],
        "action": "route",
        "outbound": "hy2"
      }
    ],
    "final": "trojan-tcp"
  }
}
