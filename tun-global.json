{
  "log": {
    "level": "info"
  },
  "dns": {
    "servers": [
      {
        "type": "https",
        "tag": "cloudflare-doh",
        "server": "1.1.1.1",
        "server_port": 443,
        "path": "/dns-query",
        "detour": "reality-tcp",
        "tls": {
          "server_name": "cloudflare-dns.com"
        }
      },
      {
        "type": "local",
        "tag": "local"
      }
    ],
    "final": "cloudflare-doh",
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": [
        "172.19.0.1/30"
      ],
      "mtu": 1500,
      "auto_route": true,
      "stack": "system"
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7890
    }
  ],
  "outbounds": [
    {
      "type": "vless",
      "tag": "reality-tcp",
      "server": "YOUR_SERVER_IP",
      "server_port": 443,
      "uuid": "00000000-0000-4000-8000-000000000000",
      "flow": "xtls-rprx-vision",
      "network": "tcp",
      "tls": {
        "enabled": true,
        "server_name": "www.cloudflare.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "YOUR_REALITY_PUBLIC_KEY",
          "short_id": "YOUR_REALITY_SHORT_ID"
        }
      }
    },
    {
      "type": "hysteria2",
      "tag": "hy2",
      "server": "YOUR_SERVER_IP",
      "server_port": 443,
      "password": "YOUR_HYSTERIA2_PASSWORD",
      "obfs": {
        "type": "salamander",
        "password": "YOUR_HYSTERIA2_OBFS_PASSWORD"
      },
      "tls": {
        "enabled": true,
        "server_name": "YOUR_SERVER_IP",
        "insecure": true,
        "certificate_public_key_sha256": [
          "YOUR_HYSTERIA2_CERT_PUBLIC_KEY_SHA256"
        ]
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": {
      "server": "local",
      "strategy": "prefer_ipv4"
    },
    "rules": [
      {
        "network": [
          "tcp",
          "udp"
        ],
        "port": 53,
        "action": "hijack-dns"
      },
      {
        "protocol": [
          "dns"
        ],
        "action": "hijack-dns"
      },
      {
        "ip_cidr": [
          "YOUR_SERVER_IP/32"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "direct"
      },
      {
        "network": [
          "udp"
        ],
        "port": 443,
        "action": "route",
        "outbound": "block"
      },
      {
        "network": [
          "tcp"
        ],
        "action": "route",
        "outbound": "reality-tcp"
      },
      {
        "network": [
          "udp"
        ],
        "action": "route",
        "outbound": "hy2"
      },
      {
        "network": [
          "icmp"
        ],
        "action": "route",
        "outbound": "direct"
      }
    ],
    "final": "reality-tcp"
  }
}
